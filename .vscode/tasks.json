{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create venv (web app)",
      "type": "shell",
      "command": "python -m venv .venv",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Install web app deps (in venv)",
      "type": "shell",
      "command": "& \"${workspaceFolder}\\.venv\\Scripts\\pip.exe\" install -r webapp/requirements.txt",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "Start Web App (Floorplan)",
      "type": "shell",
      "command": "& \"${workspaceFolder}\\.venv\\Scripts\\python.exe\" -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/webapp",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    }
  ]
}
